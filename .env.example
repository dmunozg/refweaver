# RefWeaver configuration (example values)

# OpenAI-compatible LLM
OPENAI_BASE_URL=http://127.0.0.1:11435/v1
OPENAI_API_KEY=not-needed
LLM_MODEL=
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.1
LLM_TIMEOUT_SECONDS=60
LLM_RETRIES=3

# OpenRouter (Perplexity)
OPENROUTER_API_KEY=

# OpenAlex (optional, increases rate limits)
OPENALEX_API_KEY=
OPENALEX_EMAIL=

# Semantic Scholar (optional)
SEMANTIC_SCHOLAR_API_KEY=

# Unpaywall (optional, but recommended)
UNPAYWALL_EMAIL=user@example.com

# Search adapter toggles
REFWEAVER_USE_SEMANTIC_SCHOLAR=true
REFWEAVER_USE_OPENALEX=true
REFWEAVER_USE_GOOGLE_SCHOLAR=true
REFWEAVER_USE_PERPLEXITY=true

# Enrichment parallelism
REFWEAVER_ENRICH_MAX_WORKERS=4

# Redis queueing
REFWEAVER_REDIS_URL=redis://localhost:6379/0
REFWEAVER_QUEUE_NAME=refweaver
REFWEAVER_JOB_TIMEOUT=1800

# API settings
REFWEAVER_API_KEY=
REFWEAVER_RATE_LIMIT_PER_MINUTE=0
REFWEAVER_RATE_LIMIT_BACKEND=memory
DATABASE_URL=sqlite:///./refweaver.db

# Rate limiting (seconds between requests per service)
REFWEAVER_RATE_LIMIT_SEMANTIC_SCHOLAR=1.0
REFWEAVER_RATE_LIMIT_OPENALEX=1.0
REFWEAVER_RATE_LIMIT_GOOGLE_SCHOLAR=2.0
REFWEAVER_RATE_LIMIT_PERPLEXITY=2.0
REFWEAVER_RATE_LIMIT_CROSSREF=1.0
REFWEAVER_RATE_LIMIT_UNPAYWALL=1.0
REFWEAVER_RATE_LIMIT_ANNAS_ARCHIVE=2.0
REFWEAVER_RATE_LIMIT_DOI=1.0
REFWEAVER_RATE_LIMIT_PUBLISHER=1.0
